# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SZERVER OLDALI kulcs – SOHA ne kerüljön a frontendbe (nincs VITE_ prefix!)
# A Netlify functions (koszeg-pass-checkout / -webhook / -send-email) ezzel írják
# a koszeg_passes táblát, amelyen RLS van és nincs anon INSERT policy.
# Supabase Dashboard → Settings → API → "service_role" secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# TICKET SYSTEM - Payment & Email
# ============================================================

# Stripe (Payment Processing)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Use test keys (sk_test_...) for development
# Use live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Resend (Email Service)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Apple Wallet (Passkit)
# Passphrase for your .p12 certificate
PASSKIT_PASSPHRASE=your_passphrase

# App URL (auto-set by Netlify in production)
URL=http://localhost:8888

# ============================================================
# MARKETING & SEO TOOLS
# ============================================================
# Google Tag Manager Container ID (e.g. GTM-XXXXXXX)
# If left empty, fallback Google Analytics (GA4) tag G-D0XMCLKMTC is loaded directly
VITE_GTM_ID=

# Google Search Console HTML Meta Tag Verification ID
VITE_GOOGLE_SITE_VERIFICATION=
